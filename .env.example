# -------- STT / Speech-to-text --------
# Use: azure | local | auto
STT_PROVIDER=azure

# Azure STT
AZURE_SPEECH_KEY=your_azure_speech_key
AZURE_SPEECH_REGION=westeurope
AZURE_SPEECH_LANGUAGE=da-DK

# -------- Optional: PostgreSQL --------
PGSQL_HOST=localhost
PGSQL_PORT=5432
PGSQL_DB=dailyliferoleplay
PGSQL_USER=app_user
PGSQL_PASS=app_password
PGSQL_SSLMODE=prefer

# -------- Optional: Staff auth policy --------
STAFF_EMAIL_DOMAIN=
STAFF_ROLE_OVERRIDES_JSON=
